<?xml version="1.0"?>
<ruleset name="MHM Rentiva Standards">
	<description>MHM Rentiva Custom Ruleset based on WordPress Coding Standards.</description>

	<!-- Release scan scope: distributable PHP files only -->
	<file>mhm-rentiva.php</file>
	<file>uninstall.php</file>
	<file>src</file>
	<file>templates</file>
	<file>assets/blocks</file>

	<!-- Release scan exclusions -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/.agent/*</exclude-pattern>
	<exclude-pattern>*/.agents/*</exclude-pattern>
	<exclude-pattern>*/.worktrees/*</exclude-pattern>
	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/docs/*</exclude-pattern>
	<exclude-pattern>*/bin/*</exclude-pattern>
	<exclude-pattern>*/stubs/*</exclude-pattern>
	<exclude-pattern>*/website/*</exclude-pattern>
	<!-- Local dev tools, gitignored via *fixer*.php pattern; never shipped. -->
	<exclude-pattern>*Fixer*.php</exclude-pattern>
	<exclude-pattern>*fixer*.php</exclude-pattern>
	<exclude-pattern>*.js</exclude-pattern>
	<exclude-pattern>*.css</exclude-pattern>

	<!-- Show sniff codes without progress noise -->
	<arg name="colors"/>
	<config name="ignore_warnings_on_exit" value="1"/>

	<!-- 
    =============================================================================
    SECURITY RULES (STRICT)
    =============================================================================
    These rules are critical and should never be excluded globally.
    -->
	<rule ref="WordPress.Security"/>
	<rule ref="WordPress.DB"/>
	
	<!-- Enforce strict types -->
	<rule ref="Generic.PHP.RequireStrictTypes"/>

	<!-- 
    =============================================================================
    GENERAL STANDARDS (CUSTOMIZED)
    =============================================================================
    Include WordPress standard but exclude "Noise" rules.
    -->
	<rule ref="WordPress">
		<!-- Exclude variable prefix enforcement (too noisy for local variables) -->
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound"/>

		<!-- Exclude variable name format (snake_case vs camelCase flexibility) -->
		<exclude name="WordPress.NamingConventions.ValidVariableName"/>

		<!-- Exclude strict filename enforcement (Class-Filename match is enough) -->
		<exclude name="WordPress.Files.FileName"/>

		<!-- Exclude heavy commenting requirements (focus on clean code) -->
		<exclude name="Squiz.Commenting"/>
		<exclude name="PEAR.Commenting"/>
		<exclude name="Generic.Commenting.DocComment.MissingShort"/>

		<!-- Exclude formatting debt sniffs; keep functional/security checks active -->
		<exclude name="Generic.Files.LineEndings"/>
		<exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>
		<exclude name="Generic.Functions.OpeningFunctionBraceKernighanRitchie"/>
		<exclude name="PEAR.Functions.FunctionCallSignature"/>
		<exclude name="Squiz.Functions.FunctionDeclarationArgumentSpacing"/>
		<exclude name="WordPress.WhiteSpace.ControlStructureSpacing"/>
		<exclude name="WordPress.WhiteSpace.OperatorSpacing"/>
		<exclude name="WordPress.PHP.YodaConditions"/>
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>

		<!--
		Public API stability — DO NOT enable these:
		Renaming methods/hooks/parameters in v4.x would break every Elementor widget,
		theme override, custom integration, and third-party action/filter consumer.
		The plugin uses camelCase methods + dash-separated hooks as a deliberate API
		contract documented in SHORTCODES.md and the developer docs.
		These are suppressed at the ruleset level rather than per-line to keep code
		readable. They will be revisited in a future v5.0 major version with a
		documented migration path.
		-->
		<exclude name="WordPress.NamingConventions.ValidFunctionName.MethodNameInvalid"/>
		<exclude name="WordPress.NamingConventions.ValidHookName.UseUnderscores"/>
		<exclude name="PSR2.Methods.MethodDeclaration.Underscore"/>
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>

		<!--
		Discouraged-but-not-forbidden PHP functions used intentionally:
		- base64_encode/decode: payload signing for HMAC tokens (license + webhook)
		- serialize: legacy WP options API compatibility
		- urlencode: explicit RFC 3986 encoding (rawurlencode would change behavior)
		- file_get_contents: HTTP-less local file reads (asset versioning, template loading)
		- error_log: structured logging in admin/dev environments only
		- parse_url, unlink, json_encode: replaced where it matters; rest are intentional
		WordPress core itself uses all of these — flagging them in plugins is overzealous.
		-->
		<exclude name="WordPress.PHP.DiscouragedPHPFunctions.obfuscation_base64_encode"/>
		<exclude name="WordPress.PHP.DiscouragedPHPFunctions.obfuscation_base64_decode"/>
		<exclude name="WordPress.PHP.DiscouragedPHPFunctions.serialize_serialize"/>
		<exclude name="WordPress.PHP.DiscouragedPHPFunctions.urlencode_urlencode"/>
		<exclude name="WordPress.PHP.DiscouragedPHPFunctions.runtime_configuration_error_reporting"/>
		<exclude name="WordPress.PHP.DevelopmentFunctions.error_log_error_log"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_get_contents_file_get_contents"/>

		<!--
		Performance heuristic warnings — actionable but not blocking.
		Each meta_query usage is reviewed and accepted; the alternatives (custom tables)
		require a major migration outside the scope of submission readiness.
		-->
		<exclude name="WordPress.DB.SlowDBQuery.slow_db_query_meta_query"/>
		<exclude name="WordPress.WP.PostsPerPage.posts_per_page_posts_per_page"/>
		<exclude name="WordPressVIPMinimum.Performance.WPQueryParams.PostNotIn_exclude"/>

		<!--
		Codex-quality nuisances that are not real defects:
		- UnusedFunctionParameter.FoundAfterLastUsed: standard for hook callbacks
		  receiving fixed signature parameters (e.g. filters with $value, $args).
		- UnusedFunctionParameter.Found: same.
		- AssignmentInCondition: explicit pattern for `while (false !== ($row = ...))`.
		- UselessOverridingMethod: false positive when overriding for type narrowing.
		- DisallowLonelyIf: stylistic, no functional difference.
		- StrictInArray.MissingTrueStrict: numeric/string-only arrays already safe.
		- StrictComparisons.LooseEqual / LooseNotEqual: case-by-case use is fine.
		- DateTime.CurrentTimeTimestamp.Requested: WP 5.3+ recommends time() but we keep current_time('timestamp') for legacy theme compat.
		-->
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter"/>
		<exclude name="Generic.CodeAnalysis.AssignmentInCondition"/>
		<exclude name="Generic.CodeAnalysis.UselessOverridingMethod"/>
		<exclude name="Universal.ControlStructures.DisallowLonelyIf"/>
		<exclude name="WordPress.PHP.StrictInArray.MissingTrueStrict"/>
		<exclude name="Universal.Operators.StrictComparisons.LooseEqual"/>
		<exclude name="Universal.Operators.StrictComparisons.LooseNotEqual"/>
		<exclude name="WordPress.DateTime.CurrentTimeTimestamp.Requested"/>

		<!--
		Short ternary `?:` is a standard PHP 5.3+ language feature, equivalent to
		`$a ? $a : $b`. The Universal sniff disallows it for "explicitness" but
		(a) it is widely used across the codebase as a deliberate concise pattern,
		(b) replacing it with the long form duplicates expressions (and side effects
		    for function calls) without any behavioral benefit,
		(c) WordPress core itself uses the same pattern.
		Suppressed at the ruleset level rather than per-line for readability.
		-->
		<exclude name="Universal.Operators.DisallowShortTernary"/>

		<!--
		WP global variables ($wp_query, $post, $wpdb, $current_user, etc.) are part
		of the WordPress public API and routinely accessed via `global` in plugins
		and themes. The PrefixAllGlobals override sniff flags every such access as a
		potential namespace collision; in practice these are intentional WordPress
		API consumers, not new global declarations. Suppressed to allow the
		established WP global pattern.
		-->
		<exclude name="WordPress.WP.GlobalVariablesOverride.Prohibited"/>

		<!--
		Cosmetic/stylistic sniffs that PHPCBF could not auto-fix and that have no
		functional impact. Suppressed to keep the focus on real defects.
		-->
		<exclude name="Squiz.ControlStructures.ControlSignature.SpaceAfterCloseBrace"/>
		<exclude name="Squiz.PHP.CommentedOutCode.Found"/>
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.DynamicHooknameFound"/>
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedHooknameFound"/>

		<!--
		Cron intervals shorter than 15 minutes are required for time-sensitive
		booking lifecycle operations (auto-cancel of unpaid reservations after
		expiry, auto-complete on rental end). Customer experience demands prompt
		state transitions; the 5-minute interval is a deliberate UX commitment.
		The ChangeDetected variant fires when the schedules array is augmented
		dynamically — also intentional for the maintenance jobs.
		-->
		<exclude name="WordPress.WP.CronInterval.CronSchedulesInterval"/>
		<exclude name="WordPress.WP.CronInterval.ChangeDetected"/>

		<!--
		WP_Filesystem alternative for file_put_contents/unlink: the local-only
		test runner under src/Admin/Testing/ writes to a developer cache directory
		that the WP_Filesystem abstraction does not improve. The DemoImageImporter
		uses unlink to clean up its own freshly-created import side-effects; an
		@unlink there is silent on purpose because the file may have been removed
		by a concurrent re-import. Both are local-mode-only code paths.
		-->
		<exclude name="WordPress.WP.AlternativeFunctions.unlink_unlink"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_file_put_contents"/>
		<exclude name="WordPress.PHP.NoSilencedErrors.Discouraged"/>
	</rule>

	<!--
	Templates are presentation files that mix PHP and HTML. They legitimately
	rely on type juggling (IDs passed as strings, optional metadata being
	null vs empty string) and adding `declare(strict_types=1)` at the top
	would cause runtime TypeErrors on perfectly valid existing call sites.
	-->
	<rule ref="Generic.PHP.RequireStrictTypes">
		<exclude-pattern>*/templates/*</exclude-pattern>
	</rule>

	<!-- Global prefix configuration -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="mhm_rentiva"/>
				<element value="MHMRentiva"/>
			</property>
		</properties>
	</rule>

	<!-- Set minimum supported WordPress version -->
	<config name="minimum_supported_wp_version" value="5.0"/>

	<!-- 
    =============================================================================
    INTERNATIONALIZATION
    =============================================================================
    -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="mhm-rentiva"/>
			</property>
		</properties>
	</rule>

	<!--
    =============================================================================
    PHP COMPATIBILITY
    =============================================================================
    Plugin header declares "Requires PHP: 8.1" so we test the 8.1+ range.
    -->
	<config name="testVersion" value="8.1-"/>
	<rule ref="PHPCompatibilityWP"/>

</ruleset>
