# WordPress Plugin - MHM Rentiva
# Files and directories to exclude from Git

# ============================================
# WordPress Core Files (NOT part of plugin)
# ============================================
/wp-admin/
/wp-includes/
/wp-content/themes/
/wp-content/plugins/*/
!/wp-content/plugins/mhm-rentiva/
/wp-content/uploads/
/wp-content/upgrade/
/wp-content/backup-db/
/wp-content/advanced-cache.php
/wp-content/wp-config.php
/wp-content/db.php
/wp-content/object-cache.php
/wp-content/debug.log
/wp-content/.htaccess

