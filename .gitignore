# ============================================================================
# mhm-rentiva .gitignore (Git tracking friendly)
# Goal: Keep only temporary/local artifacts ignored so real project files can be
# added to GitHub and used in git-cli test workflows.
# ============================================================================

# OS / editor noise
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# IDE / local tooling
.vscode/
.idea/
.cursor/
.helix/
.nvim/
.intelephense/
.kilocode/
.cline/
.clinerules
.clinerules/
.worktrees/

# Dependencies (local install outputs)
vendor/
node_modules/
.npm/
.yarn/

# Local WP / env / secrets
wp-config.php
.htaccess
.env
.env.*
config.local.php
secrets.php
credentials.php
*.pem
*.key
*.crt

# Build / package artifacts
dist/
build/
releases/
*.zip
*.tar.gz
*.rar
*.map
*.min.css.map
*.min.js.map
.cache/

# Language transient backups
languages/*-backup-*.pot~
languages/*-backup-*.po~
languages/*.l10n.php

# Logs and temp files
error_log
debug.log
*.log
*.tmp
*.bak
*.backup
tmp/
temp/
yedek/

# PHPUnit / test execution artifacts (not test source)
.phpunit.result.cache
tests/.phpunit.result.cache
tests/coverage/
tests/.coverage/
coverage/
phpunit_*.txt
phpunit-*.txt
phpunit*.txt
test_results.txt
.tmp_debug.log

# Keep docs/governance versioned, ignore raw evidence dumps
docs/internal/evidence/**/*.log
docs/internal/evidence/**/*.exit
!docs/internal/evidence/**/run_summary.md

# Local project noise / generated helpers
backups/
website/
specs/
stubs/
pcp/
docs/stitch-export/
.agent/skills/*/examples/
languages/*-*.json

# Temporary ad-hoc test/debug scripts
test_*.php
debug_*.php
check_*.php
*_debug.php
*_test.php

# Keep all source/docs/config by default:
# - src/, templates/, assets/, languages/
# - docs/, .github/, tests/ (source)
# - README/readme/changelog/composer/phpunit config
