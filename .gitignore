# Ignore everything by default, then whitelist plugin core files/folders
# (This keeps only the plugin content tracked in git)
/*

# Keep git metadata and .gitignore itself
!/.git/
!/.gitignore
!/.gitattributes

# Plugin core — whitelist these (and their contents)
!/src/
!/assets/
!/templates/
!/languages/
!/tests/
!/mhm-rentiva.php
!/uninstall.php
!/readme.txt
!/README.md
!/composer.json
!/changelog.json
!/phpunit.xml

#!/ Ensure whitelisted directories' contents are tracked
!/src/**
!/assets/**
!/templates/**
!/languages/**
!/tests/**

# Keep common config files
!/.github/

# Developer/editor/system files should remain ignored even if present
.DS_Store
*.log
node_modules/
vendor/
.env
.env.*
.idea/
.vscode/

# End of .gitignore — only plugin core is whitelisted

# ============================================================================
# SECTION 1: OS & System Files
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ============================================================================
# SECTION 2: IDE & Editor Configurations
# ============================================================================
.vscode/
.idea/
.cursor/
*.sublime-project
*.sublime-workspace
.project
.settings/
.buildpath
*.code-workspace
.helix/
.nvim/

# ============================================================================
# SECTION 3: Dependency Managers
# ============================================================================
# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
package-lock.json

# Composer (vendor is excluded, but composer.json is kept for reference)
vendor/
composer.lock
.phpunit.result.cache

# ============================================================================
# SECTION 4: WordPress & Local Environment
# ============================================================================
wp-config.php
.htaccess
error_log
debug.log
*.log
wp-content/debug.log
wp-content/uploads/

# ============================================================================
# SECTION 5: Build & Compiled Assets
# ============================================================================
*.map
*.min.css.map
*.min.js.map
build/
dist/
.cache/

# ============================================================================
# SECTION 6: Testing & Development Tools
# ============================================================================
# PHPUnit & Testing
tests/
!tests/
tests/*
!tests/Integration/
tests/Integration/*
!tests/Integration/Legacy/
tests/Integration/Legacy/*
!tests/Integration/Legacy/LegacyFeatureFlagTest.php
.phpunit.result.cache
coverage/
.coverage/

# IDE Analysis Cache
.intelephense/

# Test & Utility Scripts (Root Level)
test_*.php
debug_*.php
debug-*.php
check_*.php
check-*.php
search-*.php
list-*.php
*_test.php
*_debug.php
*_analiz.php
analiz*.php
ayarlar_*.php
master_validation_test.php
test_results.txt
AUDIT_REPORT_*.md
*transient*.php
*db*.php

# ============================================================================
# SECTION 7: MHM Rentiva - Local Development Exclusions
# ============================================================================
# Temporary & Backup Files
*.tmp
*.bak
*.backup
*-backup-*
*-yedek-*
yedek/
temp/
tmp/

# Development Scripts
generate-clean-pot.php
update-pot-ultimate.php
update_refund_text.php
test-i18n.php
reset_endpoints.php
mhm-tools.php
flush_rules.php
shortcode_analiz.php

# Development Directories
specs/
stubs/
bin/
website/
.github/
.kilocode/
pcp/
.clinerules/
.cline/
.clinerules

# Test Documentation
TEST-GUIDE.md
TEST-CHECKLIST.md

# ============================================================================
# SECTION 8: Language Files (Selective)
# ============================================================================
# Keep: mhm-rentiva.pot, mhm-rentiva-tr_TR.po, mhm-rentiva-tr_TR.mo
# Keep: mhm-rentiva-de_DE.po, mhm-rentiva-de_DE.mo (German)
languages/*-backup-*.pot~
languages/*-backup-*.po~
languages/*.l10n.php
languages/*-*.json
languages/mhm-rentiva-en_US.*

# ============================================================================
# SECTION 9: Archives & Releases
# ============================================================================
*.zip
*.tar.gz
*.rar
releases/

# ============================================================================
# SECTION 10: Security - Sensitive Files
# ============================================================================
.env
.env.*
*.pem
*.key
*.crt
config.local.php
secrets.php
credentials.php

# ============================================================================
# SECTION 11: Agent & AI Tool Artifacts
# ============================================================================
# Note: .agent/ is kept for workflow definitions
.agent/skills/*/examples/
.agent/skills/*/scripts/__pycache__/
*.pyc

# ============================================================================
# ESSENTIAL DIRECTORIES TO TRACK (Reference - Not Rules)
# ============================================================================
# ✅ ALWAYS TRACK:
# - src/           (Core PHP classes)
# - templates/     (Template files)
# - assets/        (CSS, JS, Images)
# - languages/     (POT, PO, MO files - main ones)
# - .agent/        (Workflow definitions)
# - mhm-rentiva.php (Main plugin file)
# - uninstall.php  (Uninstall script)
# - readme.txt     (WP.org readme)
# - README.md      (GitHub readme)
# - LICENSE        (License file)
# - changelog.json (Version history)
# ============================================================================

# Keep docs tracked.
!/docs/
!/docs/**
