{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MHM Rentiva Changelog Schema",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "version",
            "date",
            "changes"
        ],
        "properties": {
            "version": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "date": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "type": {
                "type": "string"
            },
            "changes": {
                "type": "array",
                "items": {
                    "type": "string"
                },
                "minItems": 1
            }
        },
        "additionalProperties": false
    }
}