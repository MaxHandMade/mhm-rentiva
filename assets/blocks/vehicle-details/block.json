{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/vehicle-details",
    "title": "MHM Vehicle Details",
    "category": "widgets",
    "icon": "car",
    "description": "Display single vehicle details page.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "vehicleId": {
            "type": "string",
            "default": ""
        },
        "showGallery": {
            "type": "boolean",
            "default": true
        },
        "showPrice": {
            "type": "boolean",
            "default": true
        },
        "showRating": {
            "type": "boolean",
            "default": true
        },
        "showReviews": {
            "type": "boolean",
            "default": true
        },
        "showFeatures": {
            "type": "boolean",
            "default": true
        },
        "showTechnicalSpecs": {
            "type": "boolean",
            "default": true
        },
        "showAvailability": {
            "type": "boolean",
            "default": true
        },
        "showBookingForm": {
            "type": "boolean",
            "default": true
        },
        "showSimilarVehicles": {
            "type": "boolean",
            "default": true
        },
        "showShareButtons": {
            "type": "boolean",
            "default": true
        },
        "showFavoriteButton": {
            "type": "boolean",
            "default": true
        },
        "showBreadcrumb": {
            "type": "boolean",
            "default": true
        },
        "similarVehiclesLimit": {
            "type": "string",
            "default": "4"
        },
        "showPricing": {
            "type": "boolean",
            "default": true
        },
        "showBooking": {
            "type": "boolean",
            "default": true
        },
        "showCalendar": {
            "type": "boolean",
            "default": true
        },
        "showBookingButton": {
            "type": "boolean",
            "default": true
        },
        "showCompareButton": {
            "type": "boolean",
            "default": true
        },
        "show_share_btns": {
            "type": "boolean",
            "default": true
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-vehicle-details"
    ]
}