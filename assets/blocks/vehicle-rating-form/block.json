{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/vehicle-rating-form",
    "title": "MHM Vehicle Rating Form",
    "category": "widgets",
    "icon": "star-half",
    "description": "Vehicle rating and review form.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "vehicleId": {
            "type": "string",
            "default": ""
        },
        "showStarRating": {
            "type": "boolean",
            "default": true
        },
        "showTextReview": {
            "type": "boolean",
            "default": true
        },
        "showCategoryRatings": {
            "type": "boolean",
            "default": true
        },
        "showPhotoUpload": {
            "type": "boolean",
            "default": true
        },
        "showVehiclePreview": {
            "type": "boolean",
            "default": true
        },
        "showRecommendToggle": {
            "type": "boolean",
            "default": true
        },
        "requireLogin": {
            "type": "boolean",
            "default": true
        },
        "requireBooking": {
            "type": "boolean",
            "default": true
        },
        "maxPhotos": {
            "type": "string",
            "default": "3"
        },
        "minReviewLength": {
            "type": "string",
            "default": "50"
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-vehicle-rating-form"
    ]
}