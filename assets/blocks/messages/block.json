{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/messages",
    "title": "MHM Messages",
    "category": "widgets",
    "icon": "format-chat",
    "description": "Customer messages and support threads.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "showDate": {
            "type": "boolean",
            "default": true
        },
        "showAuthorAvatar": {
            "type": "boolean",
            "default": true
        },
        "showUnreadBadge": {
            "type": "boolean",
            "default": true
        },
        "showThreadPreview": {
            "type": "boolean",
            "default": true
        },
        "showBookingLink": {
            "type": "boolean",
            "default": true
        },
        "showReplyButton": {
            "type": "boolean",
            "default": true
        },
        "filterStatus": {
            "type": "string",
            "default": "all",
            "enum": [
                "all",
                "unread",
                "read",
                "archived"
            ]
        },
        "sortBy": {
            "type": "string",
            "default": "date",
            "enum": [
                "date",
                "unread"
            ]
        },
        "sortOrder": {
            "type": "string",
            "default": "desc",
            "enum": [
                "asc",
                "desc"
            ]
        },
        "limitItems": {
            "type": "string",
            "default": "20"
        },
        "showPagination": {
            "type": "boolean",
            "default": true
        },
        "limit": {
            "type": "string",
            "default": "20"
        },
        "hideNav": {
            "type": "boolean",
            "default": false
        },
        "show_reply_btn": {
            "type": "boolean",
            "default": true
        },
        "status": {
            "type": "string",
            "default": "all"
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-messages"
    ]
}