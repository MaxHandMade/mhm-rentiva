{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/search-results",
    "title": "MHM Search Results",
    "category": "widgets",
    "icon": "car",
    "description": "Display vehicle search results with filters.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "layout": {
            "type": "string",
            "default": "grid",
            "enum": [
                "grid",
                "list",
                "compact"
            ]
        },
        "showPrice": {
            "type": "boolean",
            "default": true
        },
        "showRating": {
            "type": "boolean",
            "default": true
        },
        "showFilters": {
            "type": "boolean",
            "default": true
        },
        "showSorting": {
            "type": "boolean",
            "default": true
        },
        "showPagination": {
            "type": "boolean",
            "default": true
        },
        "showAvailability": {
            "type": "boolean",
            "default": true
        },
        "sortBy": {
            "type": "string",
            "default": "price",
            "enum": [
                "price",
                "popularity",
                "newest",
                "rating"
            ]
        },
        "sortOrder": {
            "type": "string",
            "default": "asc",
            "enum": [
                "asc",
                "desc"
            ]
        },
        "limit": {
            "type": "string",
            "default": "12"
        },
        "columns": {
            "type": "string",
            "default": "3"
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-search-results"
    ]
}