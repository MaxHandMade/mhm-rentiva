{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/my-bookings",
    "title": "MHM My Bookings",
    "category": "widgets",
    "icon": "clipboard",
    "description": "Display user's booking history.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "showVehicleImage": {
            "type": "boolean",
            "default": true
        },
        "showBookingDates": {
            "type": "boolean",
            "default": true
        },
        "showPrice": {
            "type": "boolean",
            "default": true
        },
        "showStatus": {
            "type": "boolean",
            "default": true
        },
        "showCancelButton": {
            "type": "boolean",
            "default": true
        },
        "showModifyButton": {
            "type": "boolean",
            "default": true
        },
        "showDetailsLink": {
            "type": "boolean",
            "default": true
        },
        "filterStatus": {
            "type": "string",
            "default": "all",
            "enum": [
                "all",
                "active",
                "upcoming",
                "completed",
                "cancelled"
            ]
        },
        "sortBy": {
            "type": "string",
            "default": "date",
            "enum": [
                "date",
                "status",
                "price"
            ]
        },
        "sortOrder": {
            "type": "string",
            "default": "desc",
            "enum": [
                "asc",
                "desc"
            ]
        },
        "limitResults": {
            "type": "string",
            "default": "10"
        },
        "showPagination": {
            "type": "boolean",
            "default": true
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-my-bookings"
    ]
}