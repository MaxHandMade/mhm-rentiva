{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/search",
    "title": "MHM Search Form",
    "category": "theme",
    "icon": "car",
    "description": "Professional vehicle search block with custom-built dimension and height controls.",
    "supports": {
        "html": true,
        "anchor": true,
        "align": [
            "wide",
            "full"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true,
            "__experimentalFontStyle": true,
            "__experimentalTextTransform": true,
            "__experimentalTextDecoration": true,
            "__experimentalLetterSpacing": true
        }
    },
    "attributes": {
        "layout": {
            "type": "string",
            "default": "compact"
        },
        "show_date_picker": {
            "type": "string",
            "default": "1"
        },
        "show_price_range": {
            "type": "string",
            "default": "1"
        },
        "show_fuel_type": {
            "type": "string",
            "default": "1"
        },
        "show_transmission": {
            "type": "string",
            "default": "1"
        },
        "show_seats": {
            "type": "string",
            "default": "1"
        },
        "redirect_page": {
            "type": "string",
            "default": ""
        },
        "minWidth": {
            "type": "string",
            "default": ""
        },
        "maxWidth": {
            "type": "string",
            "default": ""
        },
        "height": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "mhm-rentiva-block-search-editor",
    "editorStyle": [
        "mhm-rentiva-core-variables",
        "mhm-rentiva-block-editor-fixes"
    ]
}
