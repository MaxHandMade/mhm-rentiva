{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/vehicles-list",
    "title": "MHM Vehicles List",
    "category": "widgets",
    "icon": "car",
    "description": "Display vehicles in a list layout.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "show_price": {
            "type": "boolean",
            "default": true
        },
        "show_rating": {
            "type": "boolean",
            "default": true
        },
        "show_category": {
            "type": "boolean",
            "default": true
        },
        "show_booking_btn": {
            "type": "boolean",
            "default": true
        },
        "show_description": {
            "type": "boolean",
            "default": true
        },
        "show_features": {
            "type": "boolean",
            "default": true
        },
        "show_image": {
            "type": "boolean",
            "default": true
        },
        "show_title": {
            "type": "boolean",
            "default": true
        },
        "show_badges": {
            "type": "boolean",
            "default": true
        },
        "show_favorite_btn": {
            "type": "boolean",
            "default": true
        },
        "show_availability": {
            "type": "boolean",
            "default": false
        },
        "show_compare_btn": {
            "type": "boolean",
            "default": false
        },
        "filter_categories": {
            "type": "string",
            "default": ""
        },
        "filter_brands": {
            "type": "string",
            "default": ""
        },
        "orderby": {
            "type": "string",
            "default": "newest",
            "enum": [
                "price",
                "popularity",
                "newest",
                "rating"
            ]
        },
        "order": {
            "type": "string",
            "default": "desc",
            "enum": [
                "asc",
                "desc"
            ]
        },
        "limit": {
            "type": "string",
            "default": "10"
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-vehicles-list"
    ]
}