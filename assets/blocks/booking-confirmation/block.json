{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/booking-confirmation",
    "title": "MHM Booking Confirmation",
    "category": "widgets",
    "icon": "yes-alt",
    "description": "Display booking confirmation details.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "bookingId": {
            "type": "string",
            "default": ""
        },
        "showBookingDetails": {
            "type": "boolean",
            "default": true
        },
        "showVehicleInfo": {
            "type": "boolean",
            "default": true
        },
        "showPaymentSummary": {
            "type": "boolean",
            "default": true
        },
        "showPickupInstructions": {
            "type": "boolean",
            "default": true
        },
        "showContactInfo": {
            "type": "boolean",
            "default": true
        },
        "showPrintButton": {
            "type": "boolean",
            "default": true
        },
        "showDownloadPDF": {
            "type": "boolean",
            "default": true
        },
        "showCancelButton": {
            "type": "boolean",
            "default": false
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-booking-confirmation"
    ]
}