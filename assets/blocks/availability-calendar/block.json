{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/availability-calendar",
    "title": "MHM Availability Calendar",
    "category": "widgets",
    "icon": "calendar-alt",
    "description": "Display vehicle availability calendar.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "vehicleId": {
            "type": "string",
            "default": ""
        },
        "showVehicleSelector": {
            "type": "boolean",
            "default": true
        },
        "showLegend": {
            "type": "boolean",
            "default": true
        },
        "showPricing": {
            "type": "boolean",
            "default": true
        },
        "showBookingLinks": {
            "type": "boolean",
            "default": true
        },
        "showMonthNavigation": {
            "type": "boolean",
            "default": true
        },
        "showTodayButton": {
            "type": "boolean",
            "default": true
        },
        "showWeekNumbers": {
            "type": "boolean",
            "default": false
        },
        "monthsToShow": {
            "type": "string",
            "default": "2"
        },
        "startWeekOn": {
            "type": "string",
            "default": "1",
            "enum": [
                "0",
                "1"
            ]
        },
        "calendarHeight": {
            "type": "string",
            "default": "auto"
        },
        "theme": {
            "type": "string",
            "default": "default"
        },
        "startDate": {
            "type": "string",
            "default": ""
        },
        "monthsAhead": {
            "type": "string",
            "default": "3"
        },
        "startMonth": {
            "type": "string",
            "default": ""
        },
        "showWeekends": {
            "type": "boolean",
            "default": true
        },
        "showPastDates": {
            "type": "boolean",
            "default": false
        },
        "showSeasonalPrices": {
            "type": "boolean",
            "default": true
        },
        "showDiscounts": {
            "type": "boolean",
            "default": true
        },
        "showBookingButton": {
            "type": "boolean",
            "default": true
        },
        "integratePricing": {
            "type": "boolean",
            "default": true
        },
        "show_month_nav": {
            "type": "boolean",
            "default": true
        },
        "show_today_btn": {
            "type": "boolean",
            "default": true
        },
        "height": {
            "type": "string",
            "default": "auto"
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-availability-calendar"
    ]
}