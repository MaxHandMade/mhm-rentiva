{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/transfer-results",
    "title": "MHM Transfer Results",
    "category": "widgets",
    "icon": "airplane",
    "description": "Displays transfer search results with route cards, pricing, and booking buttons.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "layout": {
            "type": "string",
            "default": "list",
            "enum": [
                "list",
                "grid",
                "compact"
            ]
        },
        "showPrice": {
            "type": "boolean",
            "default": true
        },
        "showVehicleDetails": {
            "type": "boolean",
            "default": true
        },
        "showLuggageInfo": {
            "type": "boolean",
            "default": true
        },
        "showPassengerCount": {
            "type": "boolean",
            "default": true
        },
        "showBookButton": {
            "type": "boolean",
            "default": true
        },
        "showRouteInfo": {
            "type": "boolean",
            "default": true
        },
        "sortBy": {
            "type": "string",
            "default": "price",
            "enum": [
                "price",
                "popularity",
                "newest",
                "capacity"
            ]
        },
        "sortOrder": {
            "type": "string",
            "default": "asc",
            "enum": [
                "asc",
                "desc"
            ]
        },
        "limit": {
            "type": "string",
            "default": "10"
        },
        "columns": {
            "type": "string",
            "default": "2"
        },
        "orderby": {
            "type": "string",
            "default": "price"
        },
        "order": {
            "type": "string",
            "default": "asc",
            "enum": [
                "asc",
                "desc"
            ]
        },
        "show_booking_button": {
            "type": "boolean",
            "default": true
        },
        "showFavoriteButton": {
            "type": "boolean",
            "default": true
        },
        "showCompareButton": {
            "type": "boolean",
            "default": true
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-transfer-results"
    ]
}