{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/vehicle-comparison",
    "title": "MHM Vehicle Comparison",
    "category": "widgets",
    "icon": "columns",
    "description": "Compare multiple vehicles side by side.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "vehicleIds": {
            "type": "string",
            "default": ""
        },
        "showTechnicalSpecs": {
            "type": "boolean",
            "default": true
        },
        "showComparisonImages": {
            "type": "boolean",
            "default": true
        },
        "showPrice": {
            "type": "boolean",
            "default": true
        },
        "showRating": {
            "type": "boolean",
            "default": true
        },
        "showFeatures": {
            "type": "boolean",
            "default": true
        },
        "showBookButton": {
            "type": "boolean",
            "default": true
        },
        "showCategory": {
            "type": "boolean",
            "default": true
        },
        "showFuelType": {
            "type": "boolean",
            "default": true
        },
        "showTransmission": {
            "type": "boolean",
            "default": true
        },
        "showSeats": {
            "type": "boolean",
            "default": true
        },
        "maxVehicles": {
            "type": "string",
            "default": "4"
        },
        "layout": {
            "type": "string",
            "default": "table",
            "enum": [
                "table",
                "cards"
            ]
        },
        "title": {
            "type": "string",
            "default": ""
        },
        "manualAdd": {
            "type": "boolean",
            "default": false
        },
        "showAddVehicle": {
            "type": "boolean",
            "default": true
        },
        "showRemoveButtons": {
            "type": "boolean",
            "default": true
        },
        "showBookingButtons": {
            "type": "boolean",
            "default": true
        },
        "show_images": {
            "type": "boolean",
            "default": true
        },
        "show_prices": {
            "type": "boolean",
            "default": true
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-vehicle-comparison"
    ]
}