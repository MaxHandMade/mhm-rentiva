{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mhm-rentiva/payment-history",
    "title": "MHM Payment History",
    "category": "widgets",
    "icon": "money-alt",
    "description": "Display user's payment history.",
    "textdomain": "mhm-rentiva",
    "supports": {
        "html": false,
        "anchor": true,
        "className": true,
        "customClassName": true,
        "align": [
            "wide",
            "full",
            "center"
        ],
        "color": {
            "text": true,
            "background": true,
            "link": true,
            "gradients": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true
        }
    },
    "attributes": {
        "showInvoiceDownload": {
            "type": "boolean",
            "default": true
        },
        "showPaymentMethod": {
            "type": "boolean",
            "default": true
        },
        "showTransactionId": {
            "type": "boolean",
            "default": true
        },
        "showDate": {
            "type": "boolean",
            "default": true
        },
        "showBookingLink": {
            "type": "boolean",
            "default": true
        },
        "filterStatus": {
            "type": "string",
            "default": "all",
            "enum": [
                "all",
                "paid",
                "pending",
                "refunded",
                "failed"
            ]
        },
        "sortBy": {
            "type": "string",
            "default": "date",
            "enum": [
                "date",
                "amount",
                "status"
            ]
        },
        "sortOrder": {
            "type": "string",
            "default": "desc",
            "enum": [
                "asc",
                "desc"
            ]
        },
        "limitResults": {
            "type": "string",
            "default": "20"
        },
        "showPagination": {
            "type": "boolean",
            "default": true
        },
        "limit": {
            "type": "string",
            "default": "20"
        },
        "hideNav": {
            "type": "boolean",
            "default": false
        },
        "status": {
            "type": "string",
            "default": "all"
        },
        "className": {
            "type": "string",
            "default": ""
        }
    },
    "editorStyle": [
        "mhm-rentiva-core-variables"
    ],
    "style": [
        "mhm-rentiva-payment-history"
    ]
}